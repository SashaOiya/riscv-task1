--- /dev/null
+++ b/lib/sbi/sbi_ecall_fortune.c
@@ -0,0 +1,49 @@
+// SPDX-License-Identifier: BSD-2-Clause
+#include <sbi/sbi_ecall.h>
+#include <sbi/sbi_ecall_interface.h>
+#include <sbi/sbi_trap.h>
+#include <sbi/riscv_asm.h>
+#include <sbi/sbi_error.h>
+
+#define SBI_EXT_FORTUNE         0x0FAB0000
+#define SBI_FORTUNE_GET_CSR     0x01
+#define SBI_FORTUNE_GET_MSTATUS 0x02
+
+static const uint64_t MAGIC = 0x52495343562d4d21;
+
+static int sbi_ecall_fortune_handler(unsigned long extid, unsigned long funcid,
+				      const struct sbi_trap_regs *regs,
+				      unsigned long *out_val,
+				      struct sbi_trap_info *out_trap)
+{
+	uint64_t result = 0;
+
+	switch (funcid) {
+	case SBI_FORTUNE_GET_CSR:
+		result = csr_read(CSR_MCYCLE);
+		result = (result ^ MAGIC);
+		result = ((result << 13) | (result >> 51)) ^ 0xDEADBEEF;
+		break;
+	case SBI_FORTUNE_GET_MSTATUS:
+		result = csr_read(CSR_MSTATUS);
+		result = ~result;
+		break;
+	default:
+		return SBI_ERR_NOT_SUPPORTED;
+	}
+
+	*out_val = result;
+	return 0;
+}
+
+struct sbi_ecall_extension ecall_fortune = {
+	.extid_start = SBI_EXT_FORTUNE,
+	.extid_end   = SBI_EXT_FORTUNE,
+	.handle      = sbi_ecall_fortune_handler,
+};
+
+void sbi_ecall_fortune_register(void)
+{
+	sbi_ecall_register_extension(&ecall_fortune);
+}
+
